{
  "title": "PPTagent SLA Dashboard",
  "uid": "pptagent-sla",
  "tags": ["pptagent", "sla", "m4"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "feature",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_requests_total{service=\"pptagent-backend\"}, feature)",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Monthly Availability (SC-012: ≥99%)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{status=~\"5..\"}[30d])) / sum(rate(http_requests_total[30d])))",
          "legendFormat": "availability"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "P95 Generation Latency (SC-001: ≤5min)",
      "type": "graph",
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(generation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(generation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "MTTR (FR-025: ≤4h)",
      "type": "graph",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "avg_over_time(time_to_resolve_incidents_seconds[7d]) / 3600",
          "legendFormat": "MTTR (hours)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "h" } }
    },
    {
      "id": 4,
      "title": "Queue Length (FR-029: ≤2/user)",
      "type": "graph",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 8 },
      "targets": [
        { "expr": "queue_length", "legendFormat": "{{user_id}}" }
      ]
    },
    {
      "id": 5,
      "title": "Token Consumption by Feature",
      "type": "graph",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(tokens_consumed_total[5m])) by (feature)",
          "legendFormat": "{{feature}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rate by Feature",
      "type": "graph",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (feature) / sum(rate(http_requests_total[5m])) by (feature)",
          "legendFormat": "{{feature}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ]
}
