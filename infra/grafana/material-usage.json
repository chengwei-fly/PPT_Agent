{
  "title": "PPTagent Material Usage (US6)",
  "uid": "pptagent-material-usage",
  "tags": ["pptagent", "us6", "material"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Material Reuse Rate (FR-033 / SC-015)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(draft_slide_inserted_total{source_type=\"reused\"}) / sum(draft_slide_inserted_total)",
          "legendFormat": "reuse_rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Drafts Exported per Day",
      "type": "graph",
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(draft_exported_total[1d])) by (owner_tier)",
          "legendFormat": "{{owner_tier}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Material Search Latency (SC-015 P95 ≤1s)",
      "type": "graph",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(material_search_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Indexed Materials by Visual Type",
      "type": "piechart",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "sum(material_indexed_total) by (visual_type)",
          "legendFormat": "{{visual_type}}"
        }
      ]
    }
  ]
}
