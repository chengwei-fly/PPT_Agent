# ── Core ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=pptagent-backend
APP_VERSION=0.1.0
LOG_LEVEL=INFO
LOG_FORMAT=json
# FR-022 / Constitution §V: structured logs include three tags
LOG_NAMESPACE=pptagent

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pptagent:pptagent@localhost:5432/pptagent
DATABASE_URL_SYNC=postgresql://pptagent:pptagent@localhost:5432/pptagent
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── Redis (FR-029: 队列 + 限流) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
QUEUE_DEADLINE_SECONDS=300
RATE_LIMIT_PER_MIN=60
USER_CONCURRENCY_LIMIT=2

# ── MinIO / S3 (FR-009 三类数据分离) ──────────────────────────────────
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_HOT=ppt-hot
S3_BUCKET_COLD=ppt-cold
S3_SECURE=false
S3_REGION=us-east-1

# ── OpenTelemetry / Jaeger ───────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=pptagent-backend
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# ── Security / API Keys (Constitution §IV) ────────────────────────────
SECRET_KEY=change-me-in-production-32chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
PII_FIELDS=phone,email,id_card,customer_name,address,bank_card
PII_DETECTION_LANG=zh

# ── Generation (FR-001 / FR-004) ─────────────────────────────────────
GENERATION_TIMEOUT_SECONDS=300
GENERATION_MAX_CONCURRENCY_PER_USER=2
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-replace-with-real-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# ── ReAct agent (M-evolve: agent 化 + 50+ 页支持) ──────────────────
# 这些开关控制新的 ReAct 驱动 agent (src/agents/orchestrator.py),
# 它用 LLM 决定工具调用顺序,以取代旧的硬编码 4 阶段管道。
#
# 50 页汇报: 推荐调高 PER_PAGE + 调大 MAX,见 REACT_REFACTOR.md。
# ───────────────────────────────────────────────────────────────────

# LLMClient 重试预算: 指数退避, 上限 8s, 适用于 429/5xx/网络错误
LLM_MAX_RETRIES=3

# SVG 阶段并发: 一次同时发出 N 个 LLM 调用 (信号量上限)。
#  - 调高: 50 页渲染更快, 但 LLM 速率限制压力增大
#  - 调低: 稳, 慢
#  - 建议范围 2-8, 默认 4 适合 OpenAI tier-1/2
REACT_SVG_PARALLELISM=4

# SVG 阶段批量: 一次调用渲染多少页 (受 max_tokens 限制)。
#  - 调高: 单次 LLM 调用更省 system prompt 重复发送
#  - 调低: 失败时丢失的工作更少, 恢复更细粒度
#  - 5 是个安全默认, 大 deck (>=30 页) 可调到 6-8
REACT_SVG_BATCH_SIZE=5

# Worker 动态超时: timeout = base + per_page * n_pages, clamp 到 [120, max]
# 默认 base=60s, per_page=3s, max=2400s (40 分钟)
#  5  页 → max(120, 75)  = 120s
#  15 页 → max(120, 105) = 120s
#  30 页 → max(120, 150) = 150s
#  50 页 → max(120, 210) = 210s
#  100 页 → max(120, 360) = 360s (受 max_pages=60 限制, 实际不触发)
GENERATION_TIMEOUT_BASE_SECONDS=60
GENERATION_TIMEOUT_PER_PAGE_SECONDS=3.0
GENERATION_TIMEOUT_MAX_SECONDS=2400

# ── ReAct 调优提示 ────────────────────────────────────────────────
# 若你需要支持 100+ 页汇报, 调整建议:
#  - PER_PAGE_SECONDS 提到 5-6 (单页 LLM 调用 + 重试预算)
#  - PARALLELISM 提到 6-8 (OpenAI tier-3+ 才能跑满)
#  - MAX 提到 3600-5400 (60-90 分钟硬上限)
# 同时建议降低 BATCH_SIZE 到 4 以便更细粒度的恢复。
# ───────────────────────────────────────────────────────────────────

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# ── Data Retention (FR-026/FR-027) ───────────────────────────────────
TASK_RETENTION_DAYS=180
TASK_NOTIFY_BEFORE_DAYS=14
TASK_PURGE_DELAY_DAYS=7
SAMPLE_RETENTION_DAYS=0  # 0 = 永久（FR-026）

# ── Auth dev keys (DO NOT USE IN PROD) ────────────────────────────
DEV_API_KEY=dev-key
DEV_USER_EMAIL=dev@pptagent.local

# ── Curated material library (US6 / system-curated extension) ──────
# Visible to all users when ``source_sample_id IS NULL`` + ``metadata_json.curated=true``.
CURATED_LIBRARY_ENABLED=true
# Optional cap on a single import run (0 = unlimited)
CURATED_LIBRARY_MAX_ASSETS_PER_RUN=0
# Set true to use the multimodal LLM for visual_type/industry_tags/title.
# Falls back to deterministic keyword heuristics when no API key is set.
CURATED_LIBRARY_USE_LLM=false
# Override the multimodal model; defaults to LLM_MODEL when blank.
# Suggested: qwen-vl-max / gpt-4o-mini / gemini-1.5-flash
CURATED_LIBRARY_MULTIMODAL_MODEL=

# ── Internal rendering library (optional) ────────────────────────────
# The project ships a bundled renderer at backend/src/integrations/ppt_engine/.
# Override the following only if you want to point at an external install
# (e.g. a separately versioned clone of the renderer):
# PPTAGENT_RENDERER_ROOT=./src/integrations/ppt_engine
# PPTAGENT_RENDERER_SCRIPTS=./src/integrations/ppt_engine/scripts
# PPTAGENT_RENDERER_REFERENCES=./src/integrations/ppt_engine/references
# PPTAGENT_RENDERER_TEMPLATES=./src/integrations/ppt_engine/templates
# Set to 1 to skip the eager engine health check at import time (useful in CI).
# PPTAGENT_SKIP_INTEGRATION_CHECK=0

# ── Bundler (scripts/bundle_ppt_engine.py) ──────────────────────────
# Only used when re-bundling the upstream PPT engine into the tree.
# Resolution order used by the bundler:
#   1) PPTAGENT_UPSTREAM_SKILL_DIR   — absolute path to the upstream
#      skill directory (the one containing scripts/ and references/).
#   2) PPTAGENT_SIBLING_REPO_NAME    — name of a sibling repo (default
#      "ppt-master"); the bundler looks for
#      <repo-root>/../<name>/skills/<name>.
#   3) PPTAGENT_ALLOW_LEGACY_PATH=1  — opt-in switch that re-enables
#      the historical Windows hardcoded path
#      F:\workspace\ppt-master\skills\ppt-master for backward
#      compatibility with the original developer setup.
# PPTAGENT_UPSTREAM_SKILL_DIR=
# PPTAGENT_SIBLING_REPO_NAME=ppt-master
# PPTAGENT_ALLOW_LEGACY_PATH=0
